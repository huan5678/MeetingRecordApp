# MeetingRecordApp — example environment config.
# Copy to `.env` and fill in. `.env` is git-ignored.
#
# NOTE: API keys are stored in the OS keychain (via the `keyring` crate) at
# runtime, NOT read from .env in production. These vars are for local dev /
# first-run defaults only. Never commit real keys.

# AI provider: ollama (LOCAL, DEFAULT, no key) | openai | claude | gemini
AI_PROVIDER=ollama

# Local Ollama HTTP endpoint + model (used when AI_PROVIDER=ollama).
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Cloud provider keys (optional — only needed if you switch AI_PROVIDER).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Whisper transcription model size: tiny | base | small | medium | large-v3
# Default small/base for speed/size (PRD §4.5).
WHISPER_MODEL=small
